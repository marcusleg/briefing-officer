{
  "name": "briefing-officer",
  "version": "0.12.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:container": "podman build -t ghcr.io/marcusleg/briefing-officer:local .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate-dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "test:components": "vitest run --project components",
    "update-screenshots": "prisma db seed && playwright test --config=playwright.screenshots.config.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs)": "prettier --ignore-unknown --write"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
